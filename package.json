{
  "name": "@ledgerproof/workers",
  "version": "1.0.0",
  "description": "Cloudflare Workers binding for LedgerProof \u2014 auto-issue Article 50 receipts from edge inference.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "edge",
    "ledgerproof",
    "eu-ai-act"
  ],
  "author": "Veronica S. Dawkins <veronica@ledgerproofhq.io>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vsdawkins-creator/ledgerproof-workers.git"
  },
  "homepage": "https://ledgerproofhq.io",
  "sideEffects": false,
  "dependencies": {
    "@ledgerproof/sdk": "^1.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "@cloudflare/workers-types": "^4.20240502.0"
  }
}